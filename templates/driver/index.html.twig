{% extends 'base.html.twig' %}

{% block title %}Fahrer — Teamcontrol{% endblock %}

{% block body %}

    <div class="tc-page-header">
        <h1>Fahrer <span>Übersicht</span></h1>
        {{ include('components/Link.html.twig', {
            to: 'driver_new',
            name: 'Neuer Fahrer',
            icon_before: 'bi-plus',
            as_button: true,
        }) }}
    </div>

    <div class="row g-4">

        <div class="col-md-9">
            {% embed 'components/Card.html.twig' %}
                    {% block card_body %}
                    <div class="card-body p-2">
                    <table class="table">
                    <thead>
                        <tr>
                        <th class="text-uppercase">Name</th>
                        <th></th>
                        </tr>
                    </thead>
                        <tbody>

                    {% for driver in drivers %}
                                            <tr class="">
                            <td>{{ driver.name }}</td>
                            <td class="d-flex justify-content-end gap-2">
                                    <a href="{{ path('driver_edit', {id: driver.id}) }}"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post"
                                          action="{{ path('driver_delete', {id: driver.id}) }}"
                                          onsubmit="return confirm('Fahrer wirklich löschen?')">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                               >
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center"
                                style="padding: 2rem; color: var(--tc-muted)">
                                Keine Fahrer angelegt.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    </table>
                    </div>
                    {% endblock %}
            {% endembed %}
        </div>

        <div class="col-md-3">
           {{ include('components/Search.html.twig', {card_title: 'Suche'}) }}
        </div>

    </div>

{% endblock %}
