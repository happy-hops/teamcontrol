{% extends 'base.html.twig' %}

{% block title %}Fahrer — Teamcontrol{% endblock %}

{% block body %}

    <div class="tc-page-header">
        <h1>Fahrer <span>Übersicht</span></h1>
        <a href="{{ path('driver_new') }}" class="btn-tc-primary">
            <i class="bi bi-plus-lg me-1"></i>Neuer Fahrer
        </a>
    </div>

    <div class="row g-4">

        <div class="col-md-9">
            <div class="tc-card">
                <table class="tc-table">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width: 80px"></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for driver in drivers %}
                        <tr>
                            <td>{{ driver.name }}</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="{{ path('driver_edit', {id: driver.id}) }}"
                                       class="btn-tc-outline" style="padding: .2rem .6rem; font-size: .8rem">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post"
                                          action="{{ path('driver_delete', {id: driver.id}) }}"
                                          onsubmit="return confirm('Fahrer wirklich löschen?')">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit"
                                                class="btn-tc-outline"
                                                style="padding: .2rem .6rem; font-size: .8rem; border-color: var(--tc-danger); color: var(--tc-danger)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center"
                                style="padding: 2rem; color: var(--tc-muted)">
                                Keine Fahrer angelegt.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tc-card">
                <div class="tc-card-header">Suche</div>
                <div class="p-3">
                    <form method="get" action="{{ path('driver_index') }}">
                        <div class="tc-field">
                            <label class="tc-label" for="q">Name</label>
                            <input class="tc-input"
                                   type="search"
                                   id="q"
                                   name="q"
                                   value="{{ search }}"
                                   placeholder="Max Mustermann">
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-tc-primary" style="flex: 1">Suchen</button>
                            <a href="{{ path('driver_index') }}" class="btn-tc-outline">✕</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>

{% endblock %}
