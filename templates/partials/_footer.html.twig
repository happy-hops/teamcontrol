<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span>
        <strong style="color: var(--tc-text); font-family: var(--tc-font-display); letter-spacing: .05em;">TEAMCONTROL</strong>
        &nbsp;&copy; {{ "now"|date("Y") }}
        {% if appVersion is defined %}
            &nbsp;<span style="color: var(--tc-border)">|</span>&nbsp;v{{ appVersion }}
        {% endif %}
    </span>
    <span>
        Made with <i class="bi bi-heart-fill" style="color: var(--tc-accent)"></i>
        &mdash;
        <a href="https://www.buesing.de/" target="_blank" rel="noopener" style="color: var(--tc-muted)">buesing.de</a>
        {% if is_granted('ROLE_USER') %}
            &nbsp;<span style="color: var(--tc-border)">|</span>&nbsp;
            <a href="/docs/api/" target="_blank" rel="noopener" style="color: var(--tc-muted)">API</a>
        {% endif %}
    </span>
</div>
