{% if is_granted('ROLE_USER') %}

{% set nav = topNav('USER') %}

    {# ── Admin-Navbar ─────────────────────────────────────────── #}
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <button class="navbar-toggler border-0 text-muted"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav"
                    aria-controls="mainNav"
                    aria-expanded="false"
                    aria-label="Navigation umschalten">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="collapse navbar-collapse justify-content-between" id="mainNav">
                <ul class="navbar-nav align-items-lg-center gap-1">
                    {% for link in nav.left %}
                        <li class="nav-item">
                            {{ include('components/Link.html.twig', {
                                to: link.to,
                                name: link.name,
                                icon_before: link.icon_before,
                                active: app.request.attributes.get('_route') == path('driver_index'),

                            }) }}
                        </li>
                    {% endfor %}
                    <!--
                    <li class="nav-item">
                        {{ include('components/Link.html.twig', {
                            to: 'driver_index',
                            name: 'Fahrer',
                            icon_before: 'Fahrer',
                            active: app.request.attributes.get('_route') == path('driver_index'),
                            })
                        }}
                    </li>

                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'race' %}active{% endif %}"
                           href="{{ path('race_index') }}">
                            <i class="bi bi-flag me-1"></i>Rennen
                        </a>
                    </li>

                    {# Rennen-spezifische Links — nur wenn ein Rennen aktiv/geplant ist #}
                    {% if currentRace is defined and currentRace %}
                        <li class="nav-item d-none d-lg-block" aria-hidden="true">
                            <span style="color: var(--tc-border)">|</span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'team' %}active{% endif %}"
                               href="{{ path('team_index', {raceId: currentRace.id}) }}">
                                <i class="bi bi-people me-1"></i>Teams
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'event' %}active{% endif %}"
                               href="{{ path('race_event_index', {raceId: currentRace.id}) }}">
                                <i class="bi bi-lightning me-1"></i>Events
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'penalty' %}active{% endif %}"
                               href="{{ path('race_penalty_index', {raceId: currentRace.id}) }}">
                                <i class="bi bi-exclamation-triangle me-1"></i>Strafen
                            </a>
                        </li>
                    {% endif %}"nav-item d-none d-lg-block" aria-hidden="true">
                        <span style="color: var(--tc-border)">|</span>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {% if app.request.attributes.get('_route') starts with 'admin' %}active{% endif %}"
                           href="#" role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-gear me-1"></i>Verwaltung
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="{{ path('admin_station_index') }}">
                                    <i class="bi bi-hdd-network me-2"></i>Stationen
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ path('admin_user_index') }}">
                                    <i class="bi bi-people me-2"></i>Anwender
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="/docs/api/" target="_blank" rel="noopener">
                                    <i class="bi bi-code-slash me-2"></i>API Docs
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item ms-lg-2">
                        <a href="{{ path('logout') }}" class="nav-logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Abmelden
                        </a>
                    </li>
-->
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-1">
                   {% for link in nav.right %}
                        <li class="nav-item">
                            {{ include('components/Link.html.twig', {
                                to: link.to,
                                name: link.name,
                                icon_before: link.icon_before,
                                active: app.request.attributes.get('_route') == path('driver_index'),

                            }) }}
                        </li>
                   {% endfor %}
                </ul>
            </div>

        </div>
    </nav>

{% elseif is_granted('ROLE_TEAM') %}

    {# ── Team-Navbar: minimal, nur Logout ─────────────────────── #}
    <nav class="tc-team-navbar fixed-top">
        <div class="tc-team-navbar-inner">

            {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                <a href="?_switch_user=_exit" class="tc-team-nav-link">
                    <i class="bi bi-arrow-left me-1"></i>Zurück zum Admin
                </a>
            {% else %}
                <span></span>
            {% endif %}

            <a href="{{ path('logout') }}" class="tc-team-nav-link tc-team-nav-logout">
                <i class="bi bi-box-arrow-right me-1"></i>Abmelden
            </a>

        </div>
    </nav>

{% endif %}
