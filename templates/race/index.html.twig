{% extends 'base.html.twig' %}

{% block title %}Rennen — Teamcontrol{% endblock %}

{% block body %}

    <div class="tc-page-header">
        <h1>Rennen <span>Übersicht</span></h1>
        <a href="{{ path('race_new') }}" class="btn-tc-primary">
            <i class="bi bi-plus-lg me-1"></i>Neues Rennen
        </a>
    </div>

    <div class="tc-card">
        <table class="tc-table">
            <thead>
                <tr>
                    <th style="width: 120px">Status</th>
                    <th>Name</th>
                    <th style="width: 130px" class="text-center">Datum</th>
                    <th style="width: 80px"></th>
                </tr>
            </thead>
            <tbody>
                {% for race in races %}
                    <tr>
                        <td>
                            <span class="tc-badge tc-badge-{{ race.state.value == 0 ? 'planned' : (race.state.value == 5 ? 'active' : 'finished') }}">
                                {{ race.state.label() }}
                            </span>
                        </td>
                        <td>
                            <a href="{{ path('race_settings', {id: race.id}) }}" style="color: var(--tc-text)">
                                {{ race.name }}
                            </a>
                        </td>
                        <td class="text-center" style="color: var(--tc-muted)">
                            {{ race.scheduled ? race.scheduled|date('d.m.Y') : '—' }}
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="{{ path('race_settings', {id: race.id}) }}"
                                   class="btn-tc-outline" style="padding: .2rem .6rem; font-size: .8rem">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('race_delete', {id: race.id}) }}"
                                      onsubmit="return confirm('Rennen wirklich löschen?')">
                                    <input type="hidden" name="_method" value="DELETE">
                                    <button type="submit" class="btn-tc-outline"
                                            style="padding: .2rem .6rem; font-size: .8rem; border-color: var(--tc-danger); color: var(--tc-danger)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center" style="padding: 2rem; color: var(--tc-muted)">
                            Noch keine Rennen angelegt.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
