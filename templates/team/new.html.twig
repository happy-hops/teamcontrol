{% extends 'base.html.twig' %}

{% block title %}Neues Team — {{ race.name }}{% endblock %}

{% block body %}

    <div class="tc-page-header">
        <h1>Neues <span>Team</span></h1>
        <a href="{{ path('team_index', {raceId: race.id}) }}" class="btn-tc-outline">
            <i class="bi bi-arrow-left me-1"></i>Zurück
        </a>
    </div>

    <div class="row">
        <div class="col-md-7 col-lg-6">
            {% include 'team/_form.html.twig' with {
                action: path('team_create', {raceId: race.id})
            } %}
        </div>
    </div>

{% endblock %}
