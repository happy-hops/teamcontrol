{% extends 'base.html.twig' %}

{% block title %}{{ team.name }} — {{ race.name }}{% endblock %}

{% block body %}

    <div class="tc-page-header">
        <h1>#{{ team.position ?? '?' }} <span>{{ team.name }}</span></h1>
        <div class="d-flex gap-2">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="?_switch_user={{ team.teamToken }}" class="btn-tc-outline">
                    <i class="bi bi-person-fill-gear me-1"></i>Als Team ansehen
                </a>
            {% endif %}
            <a href="{{ path('team_edit', {raceId: race.id, id: team.id}) }}" class="btn-tc-primary">
                <i class="bi bi-pencil me-1"></i>Bearbeiten
            </a>
        </div>
    </div>

    {# ── Fahrer-Tabelle ───────────────────────────────────────── #}
    <div class="tc-card mb-5">
        <table class="tc-table">
            <thead>
            <tr>
                <th>Fahrer</th>
                <th class="text-end">Aktuelle Fahrzeit</th>
                <th class="text-end">Letzte Fahrzeit</th>
                <th class="text-end">Fahrpause</th>
                <th class="text-end">Gesamtzeit</th>
                <th class="text-end">Strafen</th>
            </tr>
            </thead>
            <tbody>
            {% for attendance in team.attendances %}
                {% set ds = driverStats[attendance.driver.id] ?? null %}
                <tr{% if ds and ds.isDriving %} style="background: rgba(232,255,0,.05)"{% endif %}>

                    <td>
                        <strong>{{ attendance.driver.name }}</strong>
                        {% if ds and ds.isDriving %}
                            <span class="tc-badge tc-badge-active ms-2">fährt</span>
                        {% endif %}
                    </td>

                    <td class="text-end">
                        {% if race.state.isActive() and ds and ds.isDriving and ds.currentDriveSeconds is not null %}
                            {% include 'team/_timer.html.twig' with {
                                mode:    'timer',
                                start:   ('now'|date('U') - ds.currentDriveSeconds) * 1000,
                                warning: race.maxTurn * 60 * 1000,
                                error:   (race.maxTurn + race.waitingPeriod) * 60 * 1000,
                                initial: ds.currentDriveSeconds|tc_seconds
                            } %}
                        {% else %}
                            <span style="color: var(--tc-muted)">—</span>
                        {% endif %}
                    </td>

                    <td class="text-end">
                        {{ (ds and not ds.isDriving and ds.lastDriveSeconds is not null) ? ds.lastDriveSeconds|tc_seconds : '—' }}
                    </td>

                    <td class="text-end">
                        {% if race.state.isActive() and ds and not ds.isDriving and ds.lastBreakSeconds is not null %}
                            {% include 'team/_timer.html.twig' with {
                                mode:     'countdown',
                                start:    ('now'|date('U') - ds.lastBreakSeconds) * 1000,
                                duration: race.breakTime * 60 * 1000,
                                initial:  ds.lastBreakSeconds|tc_seconds
                            } %}
                        {% else %}
                            <span style="color: var(--tc-muted)">—</span>
                        {% endif %}
                    </td>

                    <td class="text-end">{{ ds ? ds.totalDriveSeconds|tc_seconds : '—' }}</td>

                    <td class="text-end">
                        {% if ds and ds.penaltyCount > 0 %}
                            <span style="color: var(--tc-danger)">{{ ds.penaltyCount }}</span>
                        {% else %}0{% endif %}
                    </td>

                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
            <tr>
                <td colspan="4" class="tc-tfoot-label">Gesamt</td>
                <td class="text-end"><strong>{{ stats.totalDriveSeconds()|tc_seconds }}</strong></td>
                <td></td>
            </tr>
            </tfoot>
        </table>
    </div>

    {# ── Strafen ──────────────────────────────────────────────── #}
    <div class="tc-card mb-5">
        <div class="tc-card-header">Strafen</div>
        <table class="tc-table">
            <thead>
            <tr>
                <th style="width: 160px">Zeit</th>
                <th style="width: 180px">Fahrer</th>
                <th>Begründung</th>
            </tr>
            </thead>
            <tbody>
            {% for penalty in penalties %}
                <tr>
                    <td style="color: var(--tc-muted)">{{ penalty.createdAt|date('d.m.Y H:i') }}</td>
                    <td>{{ penalty.driver.name }}</td>
                    <td>{{ penalty.reason }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center" style="padding: 2rem; color: var(--tc-muted)">
                        Keine Strafen verhängt.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Info-Panels ──────────────────────────────────────────── #}
    <div class="tc-card mb-4">
        <div class="tc-card-header">Stammdaten</div>
        <table class="tc-table tc-info-table">
            <tbody>
            <tr><td>Startnummer</td> <td>{{ team.position ?? '—' }}</td></tr>
            <tr><td>Name</td>        <td>{{ team.name }}</td></tr>
            <tr><td>Teamleiter</td>  <td>{{ team.teamLead }}</td></tr>
            <tr>
                <td>Token</td>
                <td><code style="font-family: monospace; letter-spacing: .1em">{{ team.teamToken }}</code></td>
            </tr>
            <tr><td>Erstellt</td>    <td>{{ team.createdAt|date('d.m.Y') }}</td></tr>
            </tbody>
        </table>
    </div>

    <div class="tc-card mb-4">
        <div class="tc-card-header">Fahrer &amp; Tag-Zuordnung</div>
        <table class="tc-table tc-info-table">
            <tbody>
            {% for attendance in team.attendances %}
                <tr>
                    <td>
                        <i class="bi bi-person me-1" style="color: var(--tc-muted)"></i>
                        {{ attendance.driver.name }}
                    </td>
                    <td class="text-end">
                        {% if attendance.isUnassigned() %}
                            <span class="tc-badge" style="background: rgba(255,59,59,.1); color: var(--tc-danger); border: 1px solid var(--tc-danger)">Tag fehlt</span>
                        {% else %}
                            <span class="tc-badge tc-badge-finished">OK</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="tc-card mb-4">
        <div class="tc-card-header">Teamzeiten</div>
        <table class="tc-table tc-info-table">
            <tbody>
            <tr><td>Gesamt</td> <td>{{ stats.totalDriveSeconds()|tc_seconds }}</td></tr>
            </tbody>
        </table>
    </div>

    <a href="{{ path('team_index', {raceId: race.id}) }}" class="btn-tc-outline">
        <i class="bi bi-arrow-left me-1"></i>Zurück
    </a>

{% endblock %}
